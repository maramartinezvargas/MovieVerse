<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <title>TFG Cine · Top Películas</title>

    <meta name="description" content="Ranking de películas más valoradas obtenido desde The Movie Database (TMDB)">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS propios -->
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/hero.css">
    <link rel="stylesheet" href="/css/cards.css">
    <link rel="stylesheet" href="/css/sections.css">
</head>

<body>

<!-- HEADER -->
<header class="main-header">
    <div class="header-container">

        <!-- Logo -->
        <div class="logo">
            <a href="/">🎬 TFG Cine</a>
        </div>

        <!-- Search -->
        <form class="search-bar" action="/buscar" method="get">
            <input
                    type="text"
                    name="q"
                    placeholder="Buscar películas o series..."
                    aria-label="Buscar películas o series">
            <button type="submit">🔍</button>
        </form>

        <!-- Navigation -->
        <nav class="main-nav">
            <a href="/peliculas">Películas</a>
            <a href="/series">Series</a>
            <a href="/tendencias">Tendencias</a>
            <a href="/estrenos">Próximos estrenos</a>
        </nav>

    </div>
</header>

<!-- HERO -->
{{#featured.backdropPath}}
    <section class="hero"
             style="background-image: linear-gradient(
                     to right,
                     rgba(13,17,23,0.95),
                     rgba(13,17,23,0.6),
                     rgba(13,17,23,0.2)
                     ),
                     url('{{featured.backdropPath}}'">

        <div class="layout-container">
            <div class="hero-content">

                <span class="hero-badge">Destacado</span>

                <h1 class="hero-title">
                    {{featured.title}}
                </h1>

                <div class="hero-meta">
                <span class="rating">
                    ⭐ {{featured.voteAverageFormatted}} / 10
                    <small>({{featured.voteCount}} votos)</small>
                </span>

                    {{#featured.genres}}
                        <span class="genre">{{.}}</span>
                    {{/featured.genres}}
                </div>

                <p class="hero-overview">
                    {{featured.overview}}
                </p>

                <div class="hero-actions">
                    <a href="/peliculas/{{featured.id}}" class="btn btn-primary">
                        Ver detalles
                    </a>
                    <a href="#" class="btn btn-secondary">
                        Ver tráiler
                    </a>
                </div>

            </div>
        </div>
    </section>
{{/featured.backdropPath}}

<!-- MOVIES -->
<section class="carousel-section">
    <div class="layout-container">

        <div class="section-header">
            <h2 class="section-title">Tendencias · Top Películas</h2>

            <div class="carousel-controls">
                <button class="carousel-btn prev">‹</button>
                <button class="carousel-btn next">›</button>
            </div>
        </div>

        <div class="carousel" id="top-movies-carousel">
            {{#movies}}
                <article class="carousel-card">
                    <img src="{{posterPath}}" alt="{{title}}">
                    <div class="card-meta">
                        <span>⭐ {{voteAverageFormatted}}</span>
                        <h3>{{title}}</h3>
                    </div>
                </article>
            {{/movies}}
        </div>

    </div>
</section>

<!-- SERIES -->
<section class="carousel-section">
    <div class="layout-container">

        <div class="section-header">
            <h2 class="section-title">Tendencias · Top Series</h2>

            <div class="carousel-controls">
                <button class="carousel-btn prev">‹</button>
                <button class="carousel-btn next">›</button>
            </div>
        </div>

        <div class="carousel" id="top-tv-carousel">
            {{#tvShows}}
                <article class="carousel-card">
                    <img src="{{posterPath}}" alt="{{title}}">
                    <div class="card-meta">
                        <span>⭐ {{voteAverageFormatted}}</span>
                        <h3>{{title}}</h3>
                    </div>
                </article>
            {{/tvShows}}
        </div>

    </div>
</section>

<!-- FOOTER -->
<footer class="footer">
    <div class="layout-container">
        <p>© 2025 TFG Cine por Tamara Martinez. Datos obtenidos de <a href="https://www.themoviedb.org/" target="_blank" rel="noopener noreferrer">The Movie Database (TMDB)</a>.</p>
    </div>
</footer>
<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- JS propios -->
<!-- Carousel JS para la sección de películas: desplaza las tarjetas -->
<script src="/js/carousel.js"></script>
</body>
</html>